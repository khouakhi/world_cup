# Firebase — from Project Settings → Your apps → Web app config
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Path to the JSON file you downloaded in Step 4 (easiest method)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# football-data.org — https://www.football-data.org/ (free token, World Cup included)
FOOTBALL_DATA_API_TOKEN=

# API-Football — optional legacy; football-data.org is used for live scores
API_FOOTBALL_KEY=

# Only needed if you still use API-Football directly
API_FOOTBALL_SEASON=2022

# xAI Grok — optional match previews
XAI_API_KEY=

# Cron secret for automated sync routes
# Main family league invite code (participants auto-join this league)
MAIN_LEAGUE_INVITE_CODE=LADLL8

CRON_SECRET=local-dev-secret-change-me

NEXT_PUBLIC_APP_URL=http://localhost:3000
